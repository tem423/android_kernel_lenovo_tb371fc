/*Spruce code for OSPURCET-1208 by gaoxue4 at 2023/2/14 start*/
&pio {
	ctp_nt36532_pins_default: pins_default {
	};
	ctp_nt36532_spi_mi_mode: spi_mi {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO12__FUNC_SPI4_MI>;
			input-enable;
			drive-strength = <7>;
		};
	};
	ctp_nt36532_spi_mo_mode: spi_mo {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO13__FUNC_SPI4_MO>;
			output-low;
			drive-strength = <7>;
		};
	};
	ctp_nt36532_spi_clk_mode: spi_clk {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO64__FUNC_SPI4_CLK>;
			input-enable;
			drive-strength = <7>;
		};
	};
	ctp_nt36532_spi_csb_mode: spi_csb {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO65__FUNC_SPI4_CSB>;
			input-enable;
			drive-strength = <7>;
		};
	};
	ctp_nt36532_spi_suspend: spi_suspend {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO12__FUNC_GPIO12>,
				<PINMUX_GPIO13__FUNC_GPIO13>,
				<PINMUX_GPIO64__FUNC_GPIO64>,
				<PINMUX_GPIO65__FUNC_GPIO65>;
			input-disable;
			bias-disable;
			output-low;
		};
	};

};
/*Spruce code for OSPURCET-1208 by gaoxue4 at 2023/2/14 end*/
