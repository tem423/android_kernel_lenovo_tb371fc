name: Merge upstream v4.19.325

on:
  workflow_dispatch:
    inputs:
      target_branch:
        description: '目标分支（将用于 PR 的 base）'
        required: true
        default: '尝试同步上游'

permissions:
  contents: write
  pull-requests: write

jobs:
  merge:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          persist-credentials: false   # 我们使用 PAT 来推送

      - name: Configure git
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"

      - name: Add upstream stable remote and fetch tags
        run: |
          git remote add upstream https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git || true
          git fetch upstream --tags

      - name: Checkout merge branch
        run: git checkout merge/upstream-v4.19.325

      - name: Merge upstream v4.19.325
        id: merge
        run: |
          set -e
          git merge --no-ff upstream/v4.19.325 -m "Merge upstream v4.19.325 (a67e7cdde7cc7984ae24c3c81a70dc1aa34424b1)"

      - name: Push merge branch using PAT
        if: success()
        env:
          PAT: ${{ secrets.PAT_TOKEN }}
        run: |
          # set origin with PAT so we can push
          git remote set-url origin "https://x-access-token:${PAT}@github.com/tem423/android_kernel_lenovo_tb371fc.git"
          git push origin merge/upstream-v4.19.325

      - name: Create Pull Request using PAT
        if: success()
        uses: peter-evans/create-pull-request@v5
        with:
          token: ${{ secrets.PAT_TOKEN }}
          base: ${{ github.event.inputs.target_branch }}
          head: merge/upstream-v4.19.325
          title: "Merge upstream v4.19.325 into 尝试同步上游"
          body: |
            本 PR 自动将 upstream v4.19.325 (commit a67e7cdde7cc7984ae24c3c81a70dc1aa34424b1) 合并到仓库的目标分支（${{ github.event.inputs.target_branch }}）。

            合并方式：--no-ff merge。若合并过程中出现冲突，工作流会失败并停止，需要人工在本地或通过网页解决冲突后再次运行。

            请在 PR 中运行 CI 并在真实设备上测试亮度、传感器、音频等已知问题点。
          draft: false