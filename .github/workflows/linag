name: Sync LineageOS Kernel

on:
  # 手动触发
  workflow_dispatch:
  # 定时触发（每天北京时间早上8点）
  schedule:
    - cron: '0 0 * * *'
  # 也可以推送到 main 分支时触发（按需取消注释）
  # push:
  #   branches:
  #     - main

jobs:
  sync-kernel:
    runs-on: ubuntu-latest
    
    steps:
    - name: Checkout your repository
      uses: actions/checkout@v4
      with:
        # 获取完整历史（否则无法 push）
        fetch-depth: 0
        
    - name: Configure Git
      run: |
        git config user.name "github-actions[bot]"
        git config user.email "github-actions[bot]@users.noreply.github.com"
        
    - name: Add LineageOS kernel as remote
      run: |
        git remote add lineage https://github.com/LineageOS/android_kernel_motorola_sm8250.git
        git fetch lineage lineage-23.2 --depth=1
        
    - name: Create/Update lineage-23.2 branch
      run: |
        # 检查本地是否已有该分支
        if git show-ref --verify --quiet refs/heads/lineage-23.2; then
          git checkout lineage-23.2
          git reset --hard lineage/lineage-23.2
        else
          git checkout -b lineage-23.2 lineage/lineage-23.2
        fi
        
    - name: Push to your repository
      run: |
        git push origin lineage-23.2 --force